# Backend

# ─── AI Configuration ───────────────────────────────────────────────
# Set LLM_API_KEY to enable cloud AI. Provider is auto-detected:
#
# OpenRouter (free tier, works in Russia):
#   LLM_API_KEY=sk-or-v1-xxx
#   LLM_MODEL=qwen/qwen-2.5-72b-instruct
#
# OpenAI:
#   LLM_API_KEY=sk-xxx
#   LLM_MODEL=gpt-4o-mini
#
# Groq (free tier):
#   LLM_API_KEY=gsk_xxx
#   LLM_MODEL=llama-3.3-70b-versatile
#
# Gemini:
#   LLM_API_KEY=AIzaSyxxx
#   LLM_MODEL=gemini-2.0-flash
#
# Local Ollama:
#   LLM_URL=http://localhost:11434
#   LLM_MODEL=qwen2.5-coder:3b
#   (leave LLM_API_KEY empty)

LLM_API_KEY=
LLM_MODEL=
LLM_URL=

